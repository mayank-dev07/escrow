# Copy this file to .env.local and fill in your values.

# Solana cluster the app talks to. Use a devnet RPC URL.
# The public endpoint works for light use; for anything real use a provider
# like Helius/Triton to avoid rate limits.
NEXT_PUBLIC_RPC_URL=

# Cluster label shown in the UI and used by wallet-adapter ("devnet" | "mainnet-beta" | "testnet")
NEXT_PUBLIC_CLUSTER=

# The deployed escrow program id. Defaults to the workspace program id.
NEXT_PUBLIC_PROGRAM_ID=

# Curated demo token mints (devnet). Fill these after running `npm run mint-demo`.
# Leave blank to only show Wrapped SOL in the token dropdown.
NEXT_PUBLIC_DEMO_MINT_A=
NEXT_PUBLIC_DEMO_MINT_A_SYMBOL=
NEXT_PUBLIC_DEMO_MINT_A_DECIMALS=

NEXT_PUBLIC_DEMO_MINT_B=
NEXT_PUBLIC_DEMO_MINT_B_SYMBOL=
NEXT_PUBLIC_DEMO_MINT_B_DECIMALS=
